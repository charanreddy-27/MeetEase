# ───────────────────────────────────────────────
# MeetEase — environment variables
# Copy this file to `.env.local` and fill in the values.
# ───────────────────────────────────────────────

# Base URL of the app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Clerk (authentication) ──────────────────────
# https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Stream (video SDK) ──────────────────────────
# https://getstream.io
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_SECRET_KEY=

# ── Anthropic (AI Copilot) ──────────────────────
# https://console.anthropic.com — optional.
# Without a key, the AI copilot runs in graceful "offline mode" and live
# transcription still works (it uses the browser's Web Speech API, no key needed).
ANTHROPIC_API_KEY=
# Model id used by the copilot. Examples:
#   claude-sonnet-4-6  (fast + cost-effective, default)
#   claude-opus-4-8    (most capable)
AI_MODEL=claude-sonnet-4-6
